<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"

       >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="30dp"
            android:text="Sistem Pakar Pinus"
            android:textColor="@color/green"
            android:textSize="40dp"
            android:textStyle="bold" />



        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:layout_gravity="center"
            android:src="@drawable/ilustration" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_pine"
                style="@style/CustomCardview">

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center">


                    <ImageView
                        android:id="@+id/pine"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        app:srcCompat="@drawable/icon_pinus" />

                    <TextView
                        android:id="@+id/textView5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/pine"
                        android:layout_centerHorizontal="true"
                        android:layout_centerVertical="true"
                        android:text="Pinus"
                        android:textColor="@color/green"
                        android:textSize="16dp"
                        android:textStyle="bold" />




                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_pest"
                style="@style/CustomCardview"
                android:layout_marginStart="20dp"
                >

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center">

                    <TextView
                        android:id="@+id/txt_pest"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/pest"
                        android:layout_centerInParent="true"
                        android:text="Hama &amp; Penyakit"
                        android:textColor="@color/green"
                        android:textSize="16dp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/pest"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:layout_centerHorizontal="true"
                        app:srcCompat="@drawable/icon_hamapenyakit" />


                </RelativeLayout>

            </com.google.android.material.card.MaterialCardView>



        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">


            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_diagnosa"
                style="@style/CustomCardview"
                >


                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">


                    <ImageView
                        android:id="@+id/ic_konsul"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:layout_centerHorizontal="true"
                        app:srcCompat="@drawable/icon_konsultasi" />

                    <TextView
                        android:id="@+id/textView6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/ic_konsul"
                        android:layout_centerHorizontal="true"
                        android:text="Konsultasi"
                        android:textColor="@color/green"
                        android:textSize="16dp"
                        android:textStyle="bold"
                        tools:layout_editor_absoluteX="36dp"
                        tools:layout_editor_absoluteY="61dp" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_lahan"
                style="@style/CustomCardview"
                android:layout_marginStart="20dp"
                >

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center">

                    <ImageView
                        android:id="@+id/ic_lahan"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        app:srcCompat="@drawable/icon_kondisi_lahan" />

                    <TextView
                        android:id="@+id/textView7"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/ic_lahan"
                        android:layout_centerHorizontal="true"
                        android:text="Lahan"
                        android:textColor="@color/green"
                        android:textSize="16dp"
                        android:textStyle="bold" />

                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>


        </LinearLayout>







    </LinearLayout>

</androidx.cardview.widget.CardView>